rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures - allow public read, authenticated write
    // For development: allow all authenticated users to upload
    // In production, you may want to add user ID validation
    match /profile_pictures/{userId}/{allPaths=**} {
      // Allow public read (anyone can view profile pictures)
      allow read: if true;
      
      // Allow write (upload/delete) for authenticated requests
      // Since the app doesn't use Firebase Auth, this allows any authenticated Firebase request
      // For now, allow writes - you can restrict this later if needed
      allow write: if true; // Temporarily allow all writes for development
      // TODO: In production, restrict to: allow write: if request.auth != null;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
